t1 : Final = time()

CODE_MISSPELLING : Final = 406
CODE_DICT : Final = 207
NEAR_MISS_MAX_SCORE : Final = 6
NEAR_MISS_MAX_EDIT : Final = 2
NEAR_MISS_MIN_LEN : Final = 5
CAP_ACRONYM : Final = 'acronym'
CAP_PROPER : Final = 'proper'
CAP_MIXED : Final = 'mixed'
CAP_LOCAL : Final = 'local'
REQUEST_HEADERS : Final = {'User-Agent': 'Mozilla/5.0 (compatible; pyspell/1.0)'}

INVALID_CONTENT_PATTERNS : Final = [
    re.compile(r'(?i)sorry,\s*no\s+results'),
    re.compile(r'(?i)no\s+results\s+found'),
    re.compile(r'(?i)common\s+misspelling'),
    re.compile(r'(?i)common(?:\s|<[^>]+>)*filler(?:\s|<[^>]+>)*text'),
    re.compile(r'(?i)is\s+not\s+available\s+in\s+the\s+general\s+english\s+dictionary'),
    re.compile(r'(?i)did\s+you\s+mean'),
    re.compile(r'(?i)we\s+couldn\'?t\s+find'),
    re.compile(r'(?i)no\s+(?:exact\s+)?match(?:es)?\s+found'),
    re.compile(r'(?i)not\s+found\s+in\s+(?:the\s+)?dictionary'),
    re.compile(r'(?i)is\s+a\s+misspelling'),
    re.compile(r'(?i)no\s+dictionary\s+entry'),
    re.compile(r'(?i)<title>\s*suggestions\s*\|\s*dictionary\.com'),
    re.compile(r'(?i)did\s+you\s+mean'),
    re.compile(r'(?i)intended\s+to\s+(?:type|write|search)'),
    re.compile(r'(?i)make\s+sure\s+you\s+spelled'),
    re.compile(r'(?i)(?:search|results)\s+suggestions'),
]

def code_func(arg : str)->int:
    if re.match(r'[24]0\d', arg):
        return int(arg)
    elif arg == 'bad':
        return 405
    elif arg == 'good':
        return 205
    else:
        raise ValueError("bad arg: "+arg)

