case_words_db : Dict[str,Tuple[str,str]] = {}

def ok(code : int)->bool:
    assert type(code) == int
    return code >= 200 and code < 300

def score(w1 : str,w2 : str)->int:
    sc : Dict[str,int] = {}
    for c in w1:
        if c not in sc:
            sc[c] = 0
        sc[c] += 1
    for c in w2:
        if c not in sc:
            sc[c] = 0
        sc[c] -= 1

    wb1 : Dict[str,int] = {}
    for i in range(len(w1)-1):
        c = w1[i:i+2]
        wb1[c] = 1

    wb2 : Dict[str,int] = {}
    for i in range(len(w2)-1):
        c = w2[i:i+2]
        wb2[c] = 1

    for c in wb1:
        if c not in sc:
            sc[c] = 0
        sc[c] += 1
    for c in wb2:
        if c not in sc:
            sc[c] = 0
        sc[c] -= 1
    total = abs(len(w1)-len(w2))*3
    for k in sc.keys():
        total += abs(sc[k])
    return total

def levenshtein(w1 : str, w2 : str)->int:
    if w1 == w2:
        return 0
    prev = list(range(len(w2) + 1))
    for i, c1 in enumerate(w1, 1):
        cur = [i]
        for j, c2 in enumerate(w2, 1):
            cur.append(min(prev[j] + 1, cur[j - 1] + 1, prev[j - 1] + (c1 != c2)))
        prev = cur
    return prev[len(w2)]

def find_near_miss_valid_word(word : str)->Optional[Tuple[str,int]]:
    if len(word) < NEAR_MISS_MIN_LEN:
        return None
    fl = word[0]
    ll = word[-1]
    if ll == "'":
        ll = ""
    best = None
    best_score = NEAR_MISS_MAX_SCORE + 1
    lo = max(NEAR_MISS_MIN_LEN, len(word) - NEAR_MISS_MAX_EDIT)
    hi = len(word) + NEAR_MISS_MAX_EDIT
    for (candidate,) in cursor.execute(
            "SELECT word FROM words WHERE code >= 200 AND code < 300 "
            "AND length(word) BETWEEN ? AND ? AND word LIKE ? AND word != ?",
            (lo, hi, fl + '%' + ll, word)):
        if levenshtein(word, candidate) > NEAR_MISS_MAX_EDIT:
            continue
        s = score(candidate, word)
        if s < best_score:
            best_score = s
            best = candidate
    if best is not None and best_score <= NEAR_MISS_MAX_SCORE:
        return best, best_score
    return None

def should_downgrade_typo(word : str, candidate : str, match_score : int, code : int)->bool:
    if code == CODE_DICT:
        return False
    if len(candidate) > len(word):
        return True
    if (len(candidate) == len(word) and match_score <= 3
            and code == 200 and candidate != word):
        return True
    return False

def finalize_web_code(word : str, code : int)->int:
    if not ok(code):
        return code
    near = find_near_miss_valid_word(word)
    if near is None:
        return code
    candidate, match_score = near
    if not should_downgrade_typo(word, candidate, match_score, code):
        return code
    print(colored(
        f"  Near-miss of '{candidate}' (score={match_score}), rejecting '{word}'",
        "yellow"))
    return CODE_MISSPELLING

disable_web = not pres.enable_web #True

def html_snippet(text : str)->str:
    text = text.replace('&lt;', '<').replace('&gt;', '>').replace('&amp;', '&')
    text = text.replace('&quot;', '"').replace('&#39;', "'")
    return re.sub(r'<[^>]+>', ' ', text)

def yourdictionary_definition(word : str, content : str)->Optional[str]:
    match = re.search(
        r'(?i)content="[^"]*\b' + re.escape(word) + r'\b[^"]*definition:\s*([^"]+)"',
        content)
    if not match:
        return None
    return html_snippet(match.group(1)).strip()

def interpret_web_response(num : int, word : str, http_status : int, content : str)->int:
    if re.search(r'(?i)just a moment|cf-browser-verification|access denied', content):
        return 444

    for pattern in INVALID_CONTENT_PATTERNS:
        if pattern.search(content):
            return CODE_MISSPELLING

    if num == 1:
        if http_status == 404 or re.search(r'(?i)no\s+results\s+found', content):
            return 404

    if num == 2 and ok(http_status):
        definition = yourdictionary_definition(word, content)
        if definition is None:
            return 404
        if re.match(r'(?i)common\s+(?:misspelling|filler)\b', definition):
            return CODE_MISSPELLING

    if ok(http_status):
        return finalize_web_code(word, http_status)
    return 404

def check_web(num : int,word : str,force : bool=False)->int:
    if disable_web:
        return 444

    url = ""
    try:
        if num == 1:
            wword = word.replace("'","-")
            url = "http://www.dictionary.com/browse/%s" % wword
            res = requests.get(url, timeout=tmout, headers=REQUEST_HEADERS)
        elif num == 2:
            wword = word.replace("'","-")
            url = "https://www.yourdictionary.com/%s" % wword
            res = requests.get(url, timeout=tmout, headers=REQUEST_HEADERS)
        elif num == 3:
            pword = word.replace("'","%27")
            url = "https://www.thefreedictionary.com/%s" % pword
            sleep(2)
            res = requests.get(url, timeout=tmout, headers=REQUEST_HEADERS)
        elif num == 4:
            nword = word.replace("'","")
            url = "https://www.collinsdictionary.com/us/dictionary/english/%s" % nword
            sleep(2)
            res = requests.get(url, timeout=tmout, headers=REQUEST_HEADERS)
        else:
            return 404
    except (ConnectionError, requests.RequestException):
        print("  ",colored("Not found:","red"),url,"->",404)
        return 404

    content = res.content.decode(errors='replace')
    ret = interpret_web_response(num, word, res.status_code, content)

    if ok(ret):
        print("  ",colored("Found:","green"),url,"->",ret)
    else:
        print("  ",colored("Not found:","red"),url,"->",ret)
    return ret

def manual(word : str, code : int)->None:
    print("Action: Setting '%s' to '%d'" % (word, code))
    cursor.execute("INSERT OR REPLACE INTO words (word, code) VALUES (?, ?)", (word, code))
    conn.commit()

def case_kind(word : str)->str:
    letters = [c for c in word if c.isalpha()]
    if len(letters) >= 2 and all(c.isupper() for c in letters):
        return CAP_ACRONYM
    if len(word) > 1 and word[0].isupper() and word[1:].islower():
        return CAP_PROPER
    if any(c.isupper() for c in word[1:]):
        return CAP_MIXED
    if word and word[0].isupper():
        return CAP_PROPER
    return CAP_PROPER

def load_case_words()->None:
    case_words_db.clear()
    for lower, canonical, kind in cursor.execute(
            "SELECT lower, canonical, kind FROM case_words"):
        case_words_db[lower] = (canonical, kind)

def upsert_case_word(lower : str, canonical : str, kind : str, seen : int = 1)->None:
    row = cursor.execute(
        "SELECT canonical, kind, seen FROM case_words WHERE lower = ?",
        (lower,)).fetchone()
    if row is None:
        cursor.execute(
            "INSERT INTO case_words (lower, canonical, kind, seen) VALUES (?, ?, ?, ?)",
            (lower, canonical, kind, seen))
        case_words_db[lower] = (canonical, kind)
    elif row[0] == canonical:
        new_seen = row[2] + seen
        cursor.execute(
            "UPDATE case_words SET seen = ? WHERE lower = ?",
            (new_seen, lower))
        case_words_db[lower] = (canonical, kind)
    elif seen > row[2]:
        cursor.execute(
            "UPDATE case_words SET canonical = ?, kind = ?, seen = ? WHERE lower = ?",
            (canonical, kind, seen, lower))
        case_words_db[lower] = (canonical, kind)
    else:
        cursor.execute(
            "UPDATE case_words SET seen = ? WHERE lower = ?",
            (row[2] + seen, lower))
    conn.commit()

def pick_canonical_form(lower : str, variants : Dict[str,int])->Optional[Tuple[str,str]]:
    cased = [(form, count) for form, count in variants.items() if form != lower]
    if not cased:
        return None
    canonical, _ = max(cased, key=lambda item: item[1])
    return canonical, case_kind(canonical)

def sync_case_words_from_counts()->None:
    for lower, variants in word_counts.items():
        picked = pick_canonical_form(lower, variants)
        if picked is None:
            continue
        canonical, kind = picked
        upsert_case_word(lower, canonical, kind, variants[canonical])

def capitalization_ok(word_found : str, lower : str)->bool:
    if lower not in case_words_db:
        return True
    canonical, _ = case_words_db[lower]
    return word_found == canonical

def word_in_dict(word : str)->bool:
    if which("dict") is None:
        return False
    p = Popen(["dict",word],universal_newlines=True,stdout=PIPE,stderr=PIPE)
    o, e = p.communicate()
    #if p.returncode != 0:
    #    print(colored(f" --> word={word}, rc={p.returncode}","red"))
    return p.returncode == 0
    
def recheck_web(word : str)->int:
    global disable_web
    order = [1, 2, 3, 4]
    shuffle(order)
    status_code = 404
    for site in order:
        try:
            site_code = check_web(site, word)
        except ConnectionError:
            site_code = 444
            disable_web = True
        if ok(site_code):
            return site_code
        if site_code != 444:
            status_code = site_code
    return status_code

def audit_words(limit : int = 0)->None:
    rows = cursor.execute(
        "SELECT word, code FROM words WHERE code = 200 ORDER BY word"
    ).fetchall()
    if limit > 0:
        rows = rows[:limit]

    confirmed = 0
    downgraded = 0
    print("Auditing", len(rows), "web-cached words (code 200)...")
    for word, old_code in rows:
        if disable_web:
            print(colored("Audit stopped: web checks disabled.", "yellow"))
            break
        locals.pop(word, None)
        new_code = recheck_web(word)
        if new_code == 444:
            print(colored("Audit stopped: site blocked or unreachable.", "yellow"))
            break
        if ok(new_code):
            if new_code != old_code:
                cursor.execute("UPDATE words SET code = ? WHERE word = ?", (new_code, word))
            confirmed += 1
        else:
            print(colored(f"DOWNGRADE: {word}  {old_code} -> {new_code}", "yellow"))
            cursor.execute("UPDATE words SET code = ? WHERE word = ?", (new_code, word))
            downgraded += 1
        conn.commit()
    print(f"Audit complete: {confirmed} confirmed, {downgraded} downgraded")

def scan_near_misses(limit : int = 0)->None:
    rows = cursor.execute(
        "SELECT word, code FROM words WHERE code >= 200 AND code < 300 ORDER BY word"
    ).fetchall()
    if limit > 0:
        rows = rows[:limit]

    confirmed = 0
    downgraded = 0
    print(f"Scanning {len(rows)} valid words for near-miss typos...")
    for word, old_code in rows:
        near = find_near_miss_valid_word(word)
        if near is None:
            confirmed += 1
            continue
        candidate, match_score = near
        if not should_downgrade_typo(word, candidate, match_score, old_code):
            confirmed += 1
            continue
        cand_row = cursor.execute(
            "SELECT code FROM words WHERE word = ?", (candidate,)).fetchone()
        if cand_row is None or not ok(cand_row[0]):
            confirmed += 1
            continue
        print(colored(
            f"DOWNGRADE: {word}  near-miss of '{candidate}' "
            f"(score={match_score}, was {old_code})",
            "yellow"))
        cursor.execute(
            "UPDATE words SET code = ? WHERE word = ?",
            (CODE_MISSPELLING, word))
        conn.commit()
        locals.pop(word, None)
        downgraded += 1
    print(f"Near-miss scan complete: {confirmed} ok, {downgraded} downgraded")

LEADING_APOSTROPHE_WORDS : Final = (
    "'tis", "'twas", "'til", "'em", "'cause", "'bout", "'fore",
    "'round", "'neath",
)

def _leading_apostrophe_word(text : str, pos : int)->bool:
    if pos >= len(text) or text[pos] != "'":
        return False
    rest = text[pos:].lower()
    for prefix in LEADING_APOSTROPHE_WORDS:
        end = pos + len(prefix)
        if rest.startswith(prefix) and (end >= len(text) or not text[end].isalpha()):
            return True
    return False

def _apostrophe_inside_word(text : str, pos : int)->bool:
    return (pos > 0 and pos + 1 < len(text)
            and text[pos - 1].isalpha() and text[pos + 1].isalpha())

def _single_quote_opener(text : str, pos : int)->bool:
    if _leading_apostrophe_word(text, pos):
        return False
    if pos + 1 >= len(text) or not text[pos + 1].isalpha():
        return False
    return pos == 0 or not text[pos - 1].isalpha()

def unwrap_single_quote_delimiters(text : str)->str:
    """Drop paired quote delimiters, but keep apostrophes that belong to words."""
    out : List[str] = []
    i = 0
    n = len(text)
    in_quote = False
    while i < n:
        ch = text[i]
        if ch != "'":
            out.append(ch)
            i += 1
            continue
        if not in_quote:
            if _leading_apostrophe_word(text, i) or _apostrophe_inside_word(text, i):
                out.append("'")
                i += 1
                continue
            if _single_quote_opener(text, i):
                in_quote = True
                i += 1
                continue
            out.append("'")
            i += 1
            continue
        if _apostrophe_inside_word(text, i):
            out.append("'")
            i += 1
            continue
        in_quote = False
        i += 1
    return ''.join(out)

def normalize_token(word : str)->str:
    word = re.sub(r"’","'",word)
    word = re.sub(r"'s$","",word)
    return word

def spell_lookup_forms(word : str)->List[str]:
    forms : List[str] = []
    for candidate in (word, word.rstrip("'"), word.replace("'", "")):
        if candidate and candidate not in forms:
            forms.append(candidate)
    return forms

def load_misspellings_file(path : str)->List[str]:
    words : List[str] = []
    seen : Set[str] = set()
    with open(path, encoding='utf-8', errors='replace') as fd:
        for line in fd:
            line = line.strip()
            if not line or line.startswith('#'):
                continue
            token = line.split(None, 1)[0]
            word = normalize_token(token).lower()
            if word and word not in seen:
                seen.add(word)
                words.append(word)
    return words

def is_recorded_misspelling(word : str)->bool:
    row = cursor.execute("SELECT code FROM words WHERE word = ?", (word,)).fetchone()
    if row is None:
        return False
    return not ok(row[0])

def already_misspelling(word : str)->bool:
    return any(is_recorded_misspelling(form) for form in spell_lookup_forms(word))

def validate_misspellings_file(path : str, limit : int = 0)->None:
    if not os.path.isfile(path):
        print(colored(f"error: misspellings file not found: {path}", "red"))
        sys.exit(1)

    words = load_misspellings_file(path)
    if limit > 0:
        words = words[:limit]

    skipped = 0
    validated = 0
    valid = 0
    invalid = 0
    print(f"Validating {len(words)} words from {path}...")
    for word in words:
        if disable_web:
            print(colored("Validation stopped: web checks disabled.", "yellow"))
            break
        if already_misspelling(word):
            print(f"  SKIP {word} (already a misspelling in DB)")
            skipped += 1
            continue

        for form in spell_lookup_forms(word):
            locals.pop(form, None)

        row = cursor.execute("SELECT code FROM words WHERE word = ?", (word,)).fetchone()
        old_code = row[0] if row else None
        new_code = recheck_web(word)
        if new_code == 444:
            print(colored(f"  UNVERIFIED {word} (web blocked or unreachable)", "yellow"))
            continue
        new_code = finalize_web_code(word, new_code)

        validated += 1
        cursor.execute(
            "INSERT OR REPLACE INTO words (word, code) VALUES (?, ?)",
            (word, new_code))
        conn.commit()

        if ok(new_code):
            valid += 1
            msg = f"  VALID {word} -> {new_code}"
            if old_code is not None and not ok(old_code):
                msg += f" (was {old_code})"
            print(colored(msg, "green"))
        else:
            invalid += 1
            msg = f"  MISSPELLING {word} -> {new_code}"
            if old_code is not None and ok(old_code):
                msg += f" (was {old_code})"
            print(colored(msg, "yellow"))

    print(f"Validation complete: {validated} checked, {skipped} skipped, "
          f"{valid} valid, {invalid} misspelling")

def check(word:str,force:bool=False,ignore_locals:bool=False)->bool:
    global disable_web

    if word == "":
        return True
    if word[0] in '\\':
        return True
    for form in spell_lookup_forms(word):
        if _check_one(form, force=force, ignore_locals=ignore_locals):
            return True
    return False

def _check_one(word:str,force:bool=False,ignore_locals:bool=False)->bool:
    global disable_web

    result : Tuple[int,...]
    if not ignore_locals and word in locals:
        result = (locals[word],)
    else:
        cursor.execute("SELECT code FROM words WHERE word = ?", (word,))
        result = cursor.fetchone()
        if force or result == None:
            if word_in_dict(word):
                status_code = CODE_DICT
                cursor.execute("INSERT OR REPLACE INTO words (word, code) VALUES (?, ?)", (word, status_code))
                conn.commit()
                result = (status_code,)
        if force or result == None:
            order = [1,2,3,4]
            shuffle(order)
            if not disable_web:
                print("Try web:",word)
            for site in order:
                try:
                    status_code = check_web(site, word, force)
                except ConnectionError:
                    status_code = 444
                    disable_web = True
                if ok(status_code):
                    break
            if status_code != 444:
                cursor.execute("INSERT OR REPLACE INTO words (word, code) VALUES (?, ?)", (word, status_code))
                conn.commit()
            result = (status_code,)
        locals[word] = result[0]
    code = result[0]
    if ok(code):
        code = finalize_web_code(word, code)
        if code != result[0]:
            cursor.execute(
                "INSERT OR REPLACE INTO words (word, code) VALUES (?, ?)",
                (word, code))
            conn.commit()
            locals[word] = code
    return ok(code)

local_words_list : List[str] = []

